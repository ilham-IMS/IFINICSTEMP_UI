<RadzenStack Gap="16">
  <!-- #region List Data -->
  <DataGrid ID="GeneralDocumentDataGrid" @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="true">
    <Buttons>
      <!-- #region Toolbar -->
      <RadzenRow Gap="8">
        <RoleAccess Code="RC0000080">
          <Button ButtonStyle="ButtonStyle.Info" Text="Add" Click="@Add" Icon="add" />
        </RoleAccess>

        <RadzenStack AlignItems="AlignItems.End">
          <Button ButtonStyle="ButtonStyle.Success" Text="Print" Click="@Print" />
        </RadzenStack>
      </RadzenRow>
      <!-- #endregion -->
    </Buttons>

    <Columns>
      <DataGridColumn TItem="JsonObject" Property="DocumentName" Title="Description" Width="90%"
        Link="@(row => $"{ParentMenuURL}/generaldocument/{row["ID"]}")" />
      <DataGridColumn TItem="JsonObject" Property="IsActive" Title="Active" Width="10%" TextAlign="TextAlign.Center"
        Format="YN" />
    </Columns>
  </DataGrid>
  <!-- #endregion -->
</RadzenStack>