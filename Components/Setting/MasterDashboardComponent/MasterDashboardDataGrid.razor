<RadzenStack Gap="16">
  <!-- #region List Data -->
  <DataGrid ID="MasterDashboardDataGrid" @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="true">
    <Buttons>
      <!-- #region Toolbar -->
      <RadzenRow Gap="8">
        <RoleAccess Code="RA0000116">
          <Button ButtonStyle="ButtonStyle.Info" Text="Add" Click="@Add" Icon="add" />
        </RoleAccess>

        <RadzenStack AlignItems="AlignItems.End">
          <Button ButtonStyle="ButtonStyle.Success" Text="Print" Click="@Print" />
        </RadzenStack>
      </RadzenRow>
      <!-- #endregion -->
    </Buttons>

    <Columns>
      <DataGridColumn TItem="JsonObject" Property="Code" Title="Code" Width="20%" TextAlign="TextAlign.Center"
        Link="@(row => $"{ParentMenuURL}/masterdashboard/{row["ID"]}")" />
      <DataGridColumn TItem="JsonObject" Property="DashboardName" Title="Name" Width="30%" />
      <DataGridColumn TItem="JsonObject" Property="DashboardType" Title="Type" Width="20%" />
      <DataGridColumn TItem="JsonObject" Property="DashboardGrid" Title="Grid" Width="20%" />
      <DataGridColumn TItem="JsonObject" Property="IsActive" Title="Active" Width="10%" TextAlign="TextAlign.Center"
        Format="YN" />
    </Columns>
  </DataGrid>
  <!-- #endregion -->
</RadzenStack>