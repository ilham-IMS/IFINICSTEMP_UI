<RadzenStack Gap="16">
  <!-- #region List Data -->
  <DataGrid ID="IncentiveGroupDataGrid" @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" RowLink="@(row => $"{ParentMenuURL}/incentivegroup/{row["ID"]}")">
    <Buttons>
      <!-- #region Toolbar -->
      <RadzenRow Gap="8">
        <RoleAccess Code="RC0004893">
          <Button ButtonStyle="ButtonStyle.Info" Text="Add" Click="@Add" Icon="add" />
        </RoleAccess>

      </RadzenRow>
      <!-- #endregion -->
    </Buttons>

    <Columns>
      <DataGridColumn TItem="JsonObject" Property="IncentiveType" Title="Type" Width="30%" TextAlign="TextAlign.Center" />
      <DataGridColumn TItem="JsonObject" Property="GroupDescription" Title="Description" Width="40%" />
      <DataGridColumn TItem="JsonObject" Property="IsActive" Title="Active" Width="30%" TextAlign="TextAlign.Center"
        Format="YN" />
    </Columns>
  </DataGrid>
  <!-- #endregion -->
</RadzenStack>