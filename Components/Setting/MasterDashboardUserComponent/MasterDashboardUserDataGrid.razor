
<RadzenStack Gap="16">
  <!-- #region List Data -->
  <DataGrid ID="MasterDashboardUserDataGrid" @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="true">
    <Buttons>
      <!-- #region Toolbar -->
      <RadzenRow Gap="8">
        <RoleAccess Code="RC0000120">
          <Button ButtonStyle="ButtonStyle.Info" Text="Add" Icon="add" />
          <Button ButtonStyle="ButtonStyle.Info" Text="Save" Icon="save" Click="@UpdateOrderKey" />
        </RoleAccess>
        <RoleAccess Code="RD0000052">
          <Button ButtonStyle="ButtonStyle.Danger" Text="Delete" Click="@Delete" Icon="delete" />
        </RoleAccess>
      </RadzenRow>
      <!-- #endregion -->
    </Buttons>

    <Columns>
      <DataGridColumn TItem="JsonObject" Property="DashboardName" Title="Dashboard" Width="50%" />
      <DataGridColumn TItem="JsonObject" Property="DashboardGrid" Title="Grid" Width="30%" />
      <DataGridColumn TItem="JsonObject" Property="OrderKey" Title="Order No" Width="20%" TextAlign="TextAlign.Right">
        <Template Context="row">
          <FormFieldNumeric Value="@(row["OrderKey"]?.GetValue<int>())" />
        </Template>
      </DataGridColumn>
    </Columns>
  </DataGrid>
  <!-- #endregion -->
</RadzenStack>


