<TemplateForm Submit="@Save">
  <RadzenStack Gap="8">
    <RadzenRow Gap="32">
      <FormFieldLabel Label="Report Title" Name="ReportTitle" Value="@(rowDynamicReport["Title"]?.GetValue<string>())"
        Color="@(Color.Secondary)" />
    </RadzenRow>

    <Divider />

    <RadzenStack Gap="16">
      <DataGrid ID="MasterDynamicReportTableDataGrid" @ref=@dataGrid TItem="JsonObject" LoadData="LoadData"
        AllowSelected="@(!IsReadOnly)">
      <!-- #region Toolbar -->
      <Buttons>
      <RadzenRow Gap="8">
        @if (!IsReadOnly)
        
        {
          <RoleAccess Code="RC0004873">
            <Button ButtonStyle="ButtonStyle.Info" Text="Add" Icon="add" Click="@Add" />
          </RoleAccess>
          <RoleAccess Code="RC0004876">
            <Button ButtonStyle="ButtonStyle.Info" ButtonType="ButtonType.Submit" Text="Save" Icon="save" />
          </RoleAccess>
          <RoleAccess Code="RD0001259">
            <Button ButtonStyle="ButtonStyle.Danger" Text="Delete" Icon="delete" Click="@Delete" />
          </RoleAccess>
        }
      </RadzenRow>
      </Buttons>
      <!-- #endregion -->

      <!-- #region List Data -->
      <Columns>
        @* <RoleAccess Code="RC0001017"> *@
          <DataGridColumn TItem="JsonObject" Property="OrderKey" Title="Order" TextAlign="TextAlign.Left" Sortable="false"
            Filterable="false" Resizable="false" Width="4.2rem" Visible="@(!IsReadOnly)" OrderIndex="0">
            <Template Context="row">
              <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0"
                Style="padding: 0 0">
                <Icon IconName="expand_circle_up" Click=@(arg => OrderUp(row)) FillOnMouseOver
                  Visible="@(row["OrderKey"]?.GetValue<int>() > 1)" Style="margin-right: auto; font-size: 1.5rem;" />
                <Icon IconName="expand_circle_down" Click=@(arg => OrderDown(row)) FillOnMouseOver
                  Visible="@(row["OrderKey"]?.GetValue<int>() < dataGrid.Data?.Count())"
                  Style="margin-left: auto; font-size: 1.5rem;" />
              </RadzenStack>
            </Template>
          </DataGridColumn>
        @* </RoleAccess> *@
        <DataGridColumn TItem="JsonObject" Property="TableAlias" Title="Table" Width="30%" TextAlign="TextAlign.Left" />
        <DataGridColumn TItem="JsonObject" Property="ColumnTitle" Title="Column" Width="50%"
          TextAlign="TextAlign.Left" />
        <DataGridColumn TItem="JsonObject" Property="OrderBy" Title="Order By" Width="20%" Format="YN">
          <Template Context="row">
            @if (!IsReadOnly)
            {
              <FormFieldDropdown TValue="string" Items=@orderByDict Name="@($"OrderBy_{row["ID"]}")"
                Value="@(row["OrderBy"]?.GetValue<string>())" />
            }
            else
            {
              <span>@(row["OrderBy"]?.GetValue<string>())</span>
            }
          </Template>
        </DataGridColumn>
      </Columns>
      </DataGrid>
      <!-- #endregion -->
    </RadzenStack>
  </RadzenStack>
</TemplateForm>



<MultipleSelectLookup TItem="JsonObject" ID="DynamicReportColumnLookup" @ref="columnMultiLookup"
  LoadData="LoadDynamicReportColumnLookup" Title="Order List">
  <ToolbarTemplate>
    <Button ButtonStyle="ButtonStyle.Info" Text="Add" Icon="add" Click="@AddToList" />
  </ToolbarTemplate>

  <ColumnsTemplate>
    <DataGridColumn TItem="JsonObject" Property="TableAlias" Title="Table" Width="25%" />
    <DataGridColumn TItem="JsonObject" Property="HeaderTitle" Title="Column" Width="75%" />
  </ColumnsTemplate>
</MultipleSelectLookup>