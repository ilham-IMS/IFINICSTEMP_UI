<RadzenStack Gap="8">
  <RadzenStack>
    <SectionTitle Text="Referral Fee To Introducer List" />
  </RadzenStack>
  <RadzenStack Gap="16" Style="padding-top: 16px;">
    <!-- #region List Data -->
    <DataGrid @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="false">
      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="IntroducerName" Title="Introducer Name" Width="50%" />
      <!-- #Endregion -->

      <!-- #region Client -->
      <DataGridColumn TItem="JsonObject" Property="Rate" Title="Rate" Width="20%" />
      <!-- #Endregion -->

      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="Amount" Title="Amount" Width="30%" />
      <!-- #Endregion -->

    </DataGrid>
  </RadzenStack>
</RadzenStack>