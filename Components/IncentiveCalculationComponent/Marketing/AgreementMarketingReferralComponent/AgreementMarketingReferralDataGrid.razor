<RadzenStack Gap="8">
  <RadzenStack>
    <SectionTitle Text="Referral Fee To Introducer List" />
  </RadzenStack>
  <RadzenStack Gap="16" Style="padding-top: 16px;">
    <!-- #region List Data -->
    <DataGrid @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="false">
      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="VendorName" Title="Introducer Name" Width="50%"> 
        <Template Context="data">
          @(data["VendorName"]?.GetValue<string>() != null ? data["VendorName"]?.GetValue<string>() : data["AgentName"]?.GetValue<string>())
        </Template>
      </DataGridColumn>
      <!-- #Endregion -->

      <!-- #region Client -->
      <DataGridColumn TItem="JsonObject" Property="RefundRate" Title="Rate" Width="20%" TextAlign="TextAlign.Right">
      
        <Template Context="data">
          @((data["RefundRate"]?.GetValue<decimal>())?.ToString("N2") + "%")
        </Template>
      </DataGridColumn>
      <!-- #Endregion -->

      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="RefundAmount" Title="Amount" Width="30%" TextAlign="TextAlign.Right" Format="N2"/>
      <!-- #Endregion -->

    </DataGrid>
  </RadzenStack>
</RadzenStack>