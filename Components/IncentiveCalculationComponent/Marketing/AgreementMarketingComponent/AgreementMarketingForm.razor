@using IFinancing360_ICS_UI.Components.IncentiveCalculationComponent.Marketing.AgreementMarketingCommissionComponent
@using IFinancing360_ICS_UI.Components.IncentiveCalculationComponent.Marketing.AgreementMarketingFeeComponent
@using IFinancing360_ICS_UI.Components.IncentiveCalculationComponent.Marketing.AgreementMarketingReferralComponent
<!-- #region Form -->
<TemplateForm >
  <RadzenStack Gap="16">
    <!-- #region Toolbar -->
    <RadzenRow Gap="8">
      @* <RoleAccess Code="RC0004894">
        <Button ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Info" Text="Save" Icon="save"
           />
      </RoleAccess> *@

      <Button ButtonStyle="ButtonStyle.Danger" Text="Back" Click="Back" Icon="keyboard_backspace" />

     
      <Locker />
    </RadzenRow>
    <!-- #endregion -->
    <AgreementMarketingInfoForm ID=@ID IncentiveID=@IncentiveID />
    <Divider />
    <RadzenStack Gap="32" Style="display:flex !important; flex-direction:row !important; justify-content:space-between !important;">
      <RadzenRow Gap="32">
        <AgreementMarketingCommissionDataGrid ID=@ID AgreementID=@(row["ID"]?.GetValue<string>()) />
      </RadzenRow>
      
      <RadzenRow Gap="32" Style="border-left:1px solid #ccc !important; padding-left:32px !important;">
        <AgreementMarketingReferralDataGrid ID=@ID AgreementID=@(row["ID"]?.GetValue<string>()) />
