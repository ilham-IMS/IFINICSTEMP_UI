    </RadzenStack>
    @* <AgreementMarketingFeeDataGrid ID=@ID AgreementID=@(row["ID"]?.GetValue<string>()) /> *@
    <Divider />
    <AgreementMarketingRateForm ID=@ID IncentiveID=@IncentiveID />
    
  </RadzenStack>
