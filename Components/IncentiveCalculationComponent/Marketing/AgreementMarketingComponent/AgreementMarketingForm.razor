      <RadzenRow Gap="32">
        <AgreementMarketingFeeDataGrid ID=@ID AgreementID=@(row["ID"]?.GetValue<string>()) />
      </RadzenRow>
      
      <RadzenRow Gap="32" Style="border-left:1px solid #ccc !important; padding-left:32px !important;">
        <AgreementMarketingFeeNonInternalDataGrid ID=@ID AgreementID=@(row["ID"]?.GetValue<string>()) />
