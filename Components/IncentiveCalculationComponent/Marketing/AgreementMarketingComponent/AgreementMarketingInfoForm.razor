
<RadzenStack Gap="8">
  <!-- #region Agreement Info -->
  <RadzenRow Gap="32">
    <FormFieldTextBox Label="Agreement No" Name="AgreementNo" Value="@(row["AgreementNo"]?.GetValue<string>())" Required Max="100" Disabled />
    <FormFieldTextBox Label="Client Name" Name="ClientName" Value="@(row["ClientName"]?.GetValue<string>())" Required Max="250" Disabled />
    <FormFieldDatePicker Label="Approved Date" Name="ApprovedDate" Value="@(row["ApprovedDate"]?.GetValue<DateTime>())" Required Disabled />
  </RadzenRow>
  <!-- #endregion -->

  <!-- #region Date & Finance Info -->
  <RadzenRow Gap="32">
    <FormFieldDatePicker Label="Disbursement Date" Name="DisbursementDate" Value="@(row["DisbursementDate"]?.GetValue<DateTime>())" Required Disabled />
    <FormFieldTextBox Label="Period" Name="IncentivePeriode" Value="@(row["IncentivePeriode"]?.GetValue<string>())" Required Disabled />
    <FormFieldTextBox Label="Payment Method" Name="PaymentMethod" Value="@(row["PaymentMethod"]?.GetValue<string>())" Disabled />
  </RadzenRow>
  <!-- #endregion -->

  <!-- #region Currency & Rates -->
  <RadzenRow Gap="32">
    <FormFieldTextBox Label="Currency" Name="CurrencyCode" Value="@(row["CurrencyCode"]?.GetValue<string>())" Disabled />
    <FormFieldNumeric Label="Net Finance" Name="NetFinance" Value="@(row["NetFinance"]?.GetValue<decimal>())" Disabled />
    <FormFieldNumeric Label="Interest Rate" Name="InterestRate" Value="@(row["InterestRate"]?.GetValue<decimal>())" Disabled />
  </RadzenRow>
  <!-- #endregion -->

  <!-- #region Cost & Amounts -->
  <RadzenRow Gap="32">
    <FormFieldNumeric Label="Cost Rate" Name="CostRate" Value="@(row["CostRate"]?.GetValue<decimal>())" Disabled />
    <FormFieldNumeric Label="Interest Margin" Name="InterestMargin" Value="@(row["InterestMargin"]?.GetValue<decimal>())" Disabled />
    <FormFieldNumeric Label="Insurance Rate (Year 1 / Total Premium)" Name="InsuranceRate" Value="@(row["InsuranceRate"]?.GetValue<decimal>())" Disabled />
  </RadzenRow>
  <!-- #endregion -->

  <!-- #region Interest & Cost Amounts -->
  <RadzenRow Gap="32">
    <FormFieldNumeric Label="Interest Amount" Name="InterestAmount" Value="@(row["InterestAmount"]?.GetValue<decimal>())" Required Disabled />
    <FormFieldNumeric Label="Cost Amount" Name="CostAmount" Value="@(row["CostAmount"]?.GetValue<decimal>())" Required Disabled />
    <FormFieldNumeric Label="Interest Margin Amount" Name="InterestMarginAmount" Value="@(row["InterestMarginAmount"]?.GetValue<decimal>())" Disabled />
  </RadzenRow>
  <!-- #endregion -->
  
</RadzenStack>