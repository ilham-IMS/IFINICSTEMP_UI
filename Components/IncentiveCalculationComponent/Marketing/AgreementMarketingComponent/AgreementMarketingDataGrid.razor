<RadzenStack>
  <DataGrid @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="true" RowLink=@(row => GetLink(row))>
    <!-- #region Toolbar -->
    <Buttons>
      <RadzenRow Gap="8">
        <RoleAccess Code="RP0000669">
          <ButtonPreviewDocx Icon="print" 
              Template="@(() => GetHTML())"
              PrintAs="@((MimeType) => Print(MimeType))" 
              VisiblePDF="true" 
              VisibleExcelDataOnly="false" 
              VisibleExcel="false" 
              Text="Print"/>
        </RoleAccess>
      </RadzenRow>
    </Buttons>
    <!-- #endregion -->
    <Columns>
      <!-- #region Agreement No -->
      <DataGridColumn TItem="JsonObject" Property="AgreementNo" Title="Agreement No" Width="35%" >
        <Template Context="row">
          @(row["AgreementNo"]?.GetValue<string>())
          <br />
          @(row["ClientName"]?.GetValue<string>())
        </Template>
      </DataGridColumn>
      <!-- #endregion  -->

      <!-- #region Approved Date -->
      <DataGridColumn TItem="JsonObject" Property="ApprovedDate" Title="Approved Date" Width="30%" />
      <!-- #endregion  -->

      <!-- #region Disbursement Date -->
      <DataGridColumn TItem="JsonObject" Property="DisbursementDate" Title="Disbursement Date" Width="35%" />
      <!-- #endregion  -->

      <!-- #region Period -->
      <DataGridColumn TItem="JsonObject" Property="IncentivePeriod" Title="Period" Width="35%" TextAlign="TextAlign.Center"/>
      <!-- #endregion  -->

      <!-- #region Payment Method -->
      <DataGridColumn TItem="JsonObject" Property="PaymentMethod" Title="Payment Method" Width="35%" />
      <!-- #endregion  -->

      <!-- #region Currency -->
      <DataGridColumn TItem="JsonObject" Property="CurrencyDesc" Title="Currency" Width="35%" />
      <!-- #endregion  -->

      <!-- #region Net Finance -->
      <DataGridColumn TItem="JsonObject" Property="NetFinance" Title="Net Finance" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Interest Rate -->
      <DataGridColumn TItem="JsonObject" Property="InterestRate" Title="Interest Rate" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Cost Rate -->
      <DataGridColumn TItem="JsonObject" Property="CostRate" Title="Cost Rate" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Interest Margin -->
      <DataGridColumn TItem="JsonObject" Property="InterestMargin" Title="Interest Margin" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region BPE Ratio -->
      <DataGridColumn TItem="JsonObject" Property="BPERatio" Title="BPE Ratio" Width="35%" >
        <Template Context="row">
          @(Math.Round(row["BPERatio"]?.GetValue<decimal>() * 100 ?? 0, 1) + " %")
        </Template>
      </DataGridColumn>
      <!-- #endregion  -->

      <!-- #region Insurance Premium Usage Ratio -->
      <DataGridColumn TItem="JsonObject" Property="InsurancePremiumUsageRatio" Title="Insurance Premium Usage Ratio" Width="35%" >
        <Template Context="row">
          @(Math.Round(row["InsurancePremiumUsageRatio"]?.GetValue<decimal>() ?? 0, 2) + " %")
        </Template>
      </DataGridColumn>
      <!-- #endregion  -->

      <!-- #region BPE Effect -->
      <DataGridColumn TItem="JsonObject" Property="BPEEffect" Title="BPE Effect" Width="35%" >
        <Template Context="row">
          @(Math.Round(row["BPEEffect"]?.GetValue<decimal>() * 100 ?? 0, 2) + " %")
        </Template>
      </DataGridColumn>
      <!-- #endregion  -->

      <!-- #region BPE Income -->
      <DataGridColumn TItem="JsonObject" Property="BPEIncomeIncentiveExpense" Title="BPE Income / (Expense)" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Non Interest Effect -->
      <DataGridColumn TItem="JsonObject" Property="NonInterestEffect" Title="Non Interest Effect" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Interest Margin / Profit Before Marketing Incentive -->
      <DataGridColumn TItem="JsonObject" Property="ProfitBeforeMarketingIncentive" Title="Interest Margin / Profit Before Marketing Incentive" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Marketing Incentive Ratio / Incentive Amount -->
      <DataGridColumn TItem="JsonObject" Property="MarketingIncentiveRatio" Title="Marketing Incentive Ratio / Incentive Amount" Width="35%" Format="N2"/>
      <!-- #endregion  -->

      <!-- #region Marketing Incentive Ratio / Finance Amount -->
      <DataGridColumn TItem="JsonObject" Property="NetInterestMarginAfterCost" Title="Marketing Incentive Ratio / Finance Amount" Width="35%" Format="N2"/>
      <!-- #endregion  -->
    </Columns>
  </DataGrid>
</RadzenStack>

