<RadzenStack Gap="8">
  <RadzenStack>
    <SectionTitle Text="Commission List" />
  </RadzenStack>
  <RadzenStack Gap="16" Style="padding-top: 16px;">
    <!-- #region List Data -->
    <DataGrid @ref=@dataGrid TItem="JsonObject" LoadData="LoadData" AllowSelected="false">
      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="CommDesc" Title="Commission" Width="30%" />
      <!-- #Endregion -->

      <!-- #region Client -->
      <DataGridColumn TItem="JsonObject" Property="CommRate" Title="Commission Rate" Width="35%" TextAlign="TextAlign.Right">
        <Template Context="data">
          @(data["CommRate"]?.GetValue<decimal>() is decimal rate ? rate.ToString("N2") + "%" : "")
        </Template>
      </DataGridColumn>
      <!-- #Endregion -->

      <!-- #region Type -->
      <DataGridColumn TItem="JsonObject" Property="CommAmount" Title="Commission Amount" Width="35%" Format="N2"/>
      <!-- #Endregion -->

    </DataGrid>
  </RadzenStack>
</RadzenStack>