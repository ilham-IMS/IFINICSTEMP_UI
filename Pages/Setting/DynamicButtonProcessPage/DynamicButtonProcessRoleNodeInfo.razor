@page "/{ParentMenuURL}/dynamicbuttonprocess/{DynamicButtonProcessID}/dynamicbuttonprocessrole/{DynamicButtonProcessRoleID}/flowchartnode/add"
@using IFinancing360_ICS_UI.Components.Setting.FlowchartNodeComponent

<Title Text="Dynamic Execution Node Info" />
<RoleAccess Code="RA0002370">
<PageContainer>

   <PageLock When=@(ID != null)>

      <NodeForm DynamicButtonProcessRoleID="@DynamicButtonProcessRoleID" DynamicButtonProcessID="@DynamicButtonProcessID" ParentMenuURL=@ParentMenuURL />
   </PageLock>
</PageContainer>
</RoleAccess>

@code {
   [Parameter] public string? ID { get; set; }
   [Parameter] public string? DynamicButtonProcessID { get; set; }
   [Parameter] public string? DynamicButtonProcessRoleID { get; set; }
   [Parameter] public string? ParentMenuURL { get; set; }

}