@page "/{ParentMenuURL}/incentivescheme/add"
@page "/{ParentMenuURL}/incentivescheme/{ID}"

@using IFinancing360_ICS_UI.Components.Setting.IncentiveSchemeComponent
@using IFinancing360_ICS_UI.Components.Setting.IncentiveSchemeDetailComponent

<ReleaseLock />

<Title Text="Incentive Scheme Info" />

<RoleAccess Code="RA0002367">
  <PageContainer>
    <PageLock When="@(ID != null)">
      <IncentiveSchemeForm ID=@ID ParentMenuURL=@ParentMenuURL RowChanged=@(async arg => {
          IncentiveScheme = arg;
          if (incentiveSchemeDetailDataGrid?.dataGrid != null)
          {
            await incentiveSchemeDetailDataGrid.dataGrid.Reload();
          }
        })
        @ref="incentiveSchemeForm"
        />

      @if (ID != null && IncentiveScheme["IncentiveType"]?.GetValue<string>() == "COLLECTION")
      {
        <Divider />
        <SectionTitle Text="Scheme Detail List" />
        <IncentiveSchemeDetailDataGrid SchemeID="@ID" ParentMenuURL="@ParentMenuURL" @ref="incentiveSchemeDetailDataGrid" ReloadParent="@(() => incentiveSchemeForm?.GetRow())"/>
      }

    </PageLock>
  </PageContainer>
</RoleAccess>

@code {
  [Parameter] public string? ID { get; set; }
  [Parameter] public string? ParentMenuURL { get; set; }
  public JsonObject? IncentiveScheme { get; set; } = [];
  IncentiveSchemeDetailDataGrid incentiveSchemeDetailDataGrid;
  IncentiveSchemeForm? incentiveSchemeForm;
}