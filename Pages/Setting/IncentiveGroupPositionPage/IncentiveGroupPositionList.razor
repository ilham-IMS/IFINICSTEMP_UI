@page "/{ParentMenuURL}/incentivegroup/{IncentiveGroupID}/position"

@using IFinancing360_ICS_UI.Components.Setting.IncentiveGroupCriteriaComponent
@using IFinancing360_ICS_UI.Components.Setting.IncentiveGroupPositionComponent
@using IFinancing360_ICS_UI.Components.PanelMenuComponent

<Title Text="Position List" />

<IncentiveGroupPanelMenu IncentiveGroupID=@IncentiveGroupID>
    <PageContainer>
      <IncentiveGroupCriteriaLabel ID="@IncentiveGroupID"/>
      <Divider />
      <IncentiveGroupPositionDataGrid IncentiveGroupID=@IncentiveGroupID ParentMenuURL=@ParentMenuURL />
    </PageContainer>
</IncentiveGroupPanelMenu>

@code {
  [Parameter] public string? IncentiveGroupID { get; set; }
  [Parameter] public string? ParentMenuURL { get; set; }
}