@page "/{ParentMenuURL}/masterdynamicbuttonprocess/add"
@page "/{ParentMenuURL}/masterdynamicbuttonprocess/{ID}"
@using IFinancing360_ICS_UI.Components.Setting.MasterDynamicButtonProcessComponent

<Title Text="Master Dynamic Button Process Info" />
<RoleAccess Code="RA0002359">
  <PageContainer>

    <PageLock When=@(ID != null)>


      <MasterDynamicButtonProcessForm ID="@ID" ParentMenuURL=@ParentMenuURL />

      
